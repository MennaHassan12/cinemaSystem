@model IEnumerable<cinemaSystem.Models.Movie>

@{
    ViewData["Title"] = "Movies";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div>

    <div class="d-flex justify-content-between align-items-center mb-3">

        <a asp-area="Admin"
           asp-controller="Movies"
           asp-action="Create"
           class="btn btn-add">
            + Add New Movie
        </a>
    </div>

    <table class="table table-hover">

        <thead>
            <tr>
                <th>Main</th>
                <th>Name</th>
                <th>Price</th>
                <th>Category</th>
                <th>Cinema</th>
                <th>Gallery</th>
                <th>Actors</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var movie in Model)
            {
                <tr>

                    <td>
                        <img src="@(string.IsNullOrEmpty(movie.MainImage)
                                                                 ? "/Images/default.png"
                                                                 : movie.MainImage)"
                             width="50"
                             height="50"
                             style="object-fit:cover;border-radius:6px;" />
                    </td>

                    <td>@movie.Name</td>
                    <td>@movie.Price</td>
                    <td>@movie.Category?.Name</td>
                    <td>@movie.Cinema?.Name</td>

                    <td>
                        @if (movie.Images != null && movie.Images.Any())
                        {
                            foreach (var img in movie.Images)
                            {
                                <img src="@img.ImageUrl"
                                     width="40"
                                     height="40"
                                     style="object-fit:cover;border-radius:5px;margin-right:3px;" />
                            }
                        }
                        else
                        {
                            <span>No Images</span>
                        }
                    </td>

                    <td>
                        @string.Join(", ", movie.MovieActors.Select(a => a.Actor.Name))
                    </td>

                    <td>
                        <a asp-area="Admin"
                           asp-controller="Movies"
                           asp-action="Edit"
                           asp-route-id="@movie.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-area="Admin"
                           asp-controller="Movies"
                           asp-action="Delete"
                           asp-route-id="@movie.Id"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>
                    </td>

                </tr>
            }
        </tbody>

    </table>

</div>