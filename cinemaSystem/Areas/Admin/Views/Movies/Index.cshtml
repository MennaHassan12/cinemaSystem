@model IEnumerable<cinemaSystem.Models.Movie>

@{
    ViewData["Title"] = "Movies";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Movies List</h2>
        <a asp-area="Admin" asp-action="Create" class="btn btn-primary">+ Add New Movie</a>
    </div>

    <div class="table-container">
        <table class="table table-hover">
            <thead>
                <tr><th>Poster</th><th>Name</th><th>Price</th><th>Category</th><th>Cinema</th><th>Actions</th>
                    <th>Actors</th></tr>
            </thead>
            <tbody>
                @foreach (var movie in Model)
                {
                    <tr>
                        <td><img src="@(string.IsNullOrEmpty(movie.MainImage) ? "" : movie.MainImage)" width="50" style="height:50px; object-fit:cover;"></td>
                        <td>@movie.Name</td>
                        <td>@movie.Price.ToString("C")</td>
                        <td>@movie.Category?.Name</td>
                        <td>@movie.Cinema?.Name</td>
                        <td>
                            @string.Join(", ", movie.MovieActors.Select(e => e.Actor.Name))
                        </td>
                        <td>
                            <a asp-area="Admin" asp-action="Edit" asp-route-id="@movie.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-area="Admin" asp-action="Delete" asp-route-id="@movie.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>