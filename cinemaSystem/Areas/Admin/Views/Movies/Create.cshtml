@model cinemaSystem.Models.Movie

@{
    ViewData["Title"] = "Add Cinema";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


<div class="row justify-content-center" data-aos="fade-up">
    <div class="col-md-10">

        <div class="card shadow-sm">

            <div class="card-header bg-white">
                <h4><i class="fas fa-plus-circle"></i> Add New Movie</h4>
            </div>

            <div class="card-body">

                <form asp-area="Admin"
                      asp-controller="Movies"
                      asp-action="Create"
                      method="post"
                      enctype="multipart/form-data">

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label>Movie Name</label>
                            <input asp-for="Name" class="form-control" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Price</label>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label>Start Date</label>
                            <input asp-for="DateTime" class="form-control" type="date" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Category</label>
                            <select asp-for="CategoryId"
                                    class="form-control"
                                    asp-items="@(new SelectList(ViewBag.Categories ?? new List<cinemaSystem.Models.Category>(), "Id", "Name"))">
                                <option value="">-- Select Category --</option>
                            </select>
                        </div>

                    </div>

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label>Cinema</label>
                            <select asp-for="CinemaId"
                                    class="form-control"
                                    asp-items="@(new SelectList(ViewBag.Cinemas ?? new List<cinemaSystem.Models.Cinema>(), "Id", "Name"))">
                                <option value="">-- Select Cinema --</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Main Image</label>
                            <input type="file" name="MainImageFile" class="form-control" />
                        </div>

                    </div>

                    <div class="mb-3">
                        <label>Sub Images</label>
                        <input type="file" name="SubImages" multiple class="form-control" />
                        <small class="text-muted">You can select multiple images</small>
                    </div>

                    <div class="mb-3">
                        <label>Select Actors</label>

                        <select name="selectedActors"
                                class="form-control"
                                multiple size="8"
                                asp-items="@(new SelectList(ViewBag.Actors ?? new List<cinemaSystem.Models.Actor>(), "Id", "Name"))">
                        </select>

                        <small class="text-muted">Hold Ctrl (or Cmd) to select multiple actors</small>
                    </div>

                    <button type="submit" class="btn btn-success">
                        Save Movie
                    </button>
                    <a asp-area="Admin"
                       asp-controller="Movies"
                       asp-action="Index"
                       class="btn btn-secondary">
                        Cancel
                    </a>

                </form>

            </div>

        </div>

    </div>
</div>