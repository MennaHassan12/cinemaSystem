@model cinemaSystem.Models.Movie

@{
    ViewData["Title"] = "Edit Movie";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-10">

        <div class="card">

            <div class="card-header bg-white">
                <h4>Edit Movie</h4>
            </div>

            <div class="card-body">

                <form asp-action="Edit" enctype="multipart/form-data">

                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Name</label>
                            <input asp-for="Name" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Price</label>
                            <input asp-for="Price" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label>Main Image</label>
                        <input type="file" name="mainImageFile" class="form-control" />

                        <br />

                        @if (!string.IsNullOrEmpty(Model.MainImage))
                        {
                            <img src="@Model.MainImage"
                                 width="100"
                                 style="border-radius:8px;object-fit:cover;" />
                        }
                    </div>

                    <div class="mb-3">
                        <label>Sub Images (Add More)</label>
                        <input type="file" name="subImages" multiple class="form-control" />

                        <br />

                        @if (Model.Images != null && Model.Images.Any())
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var img in Model.Images)
                                {
                                    <img src="@img.ImageUrl"
                                         width="80"
                                         height="80"
                                         style="object-fit:cover;border-radius:6px;" />
                                }
                            </div>
                        }
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Category</label>
                            <select asp-for="CategoryId"
                                    class="form-control"
                                    asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Cinema</label>
                            <select asp-for="CinemaId"
                                    class="form-control"
                                    asp-items="@(new SelectList(ViewBag.Cinemas, "Id", "Name"))">
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label>Actors</label>
                        <select name="selectedActors"
                                multiple
                                class="form-control"
                                asp-items="@(new SelectList(ViewBag.Actors, "Id", "Name", ViewBag.SelectedActors))">
                        </select>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        Back
                    </a>

                </form>

            </div>

        </div>

    </div>
</div>