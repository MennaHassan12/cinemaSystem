@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel - @ViewData["Title"]</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin-theme.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            overflow-y: auto;
        }

        .main-content {
            margin-left: 250px;
            width: calc(100% - 250px);
        }

        .nav-link {
            padding: 10px;
            border-radius: 6px;
        }

            .nav-link:hover {
                background-color: rgba(255,255,255,0.1);
            }
    </style>
</head>

<body>

    <div class="container-fluid">
        <div class="row">

            <nav class="sidebar bg-dark p-3">
                <h5 class="text-white text-center mb-4">
                    <i class="fas fa-film"></i> Cinema Admin
                </h5>

                <ul class="nav flex-column">

                    <li class="nav-item mb-1">
                        <a class="nav-link text-white" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                            <i class="fas fa-tachometer-alt"></i> Dashboard
                        </a>
                    </li>

                    <li class="nav-item mb-1">
                        <a class="nav-link text-white" asp-area="Admin" asp-controller="Actors" asp-action="Index">
                            <i class="fas fa-users"></i> Actors
                        </a>
                    </li>

                    <li class="nav-item mb-1">
                        <a class="nav-link text-white" asp-area="Admin" asp-controller="Movies" asp-action="Index">
                            <i class="fas fa-film"></i> Movies
                        </a>
                    </li>

                    <li class="nav-item mb-1">
                        <a class="nav-link text-white" asp-area="Admin" asp-controller="Cinemas" asp-action="Index">
                            <i class="fas fa-building"></i> Cinemas
                        </a>
                    </li>

                    <li class="nav-item mb-1">
                        <a class="nav-link text-white" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                            <i class="fas fa-tags"></i> Categories
                        </a>
                    </li>

                </ul>
            </nav>

            <main class="main-content px-4">

                <div class="pt-3 pb-2 mb-3 border-bottom">
                    <h2>@ViewData["Title"]</h2>
                </div>
                @if (TempData.Peek("Success") != null)
                {
                    <div class="alert alert-success notification">
                        @TempData["Success"]
                    </div>
                }

                @if (TempData.Peek("Error") != null)
                {
                    <div class="alert alert-danger notification">
                        @TempData["Error"]
                    </div>
                }
                @RenderBody()

            </main>

        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>