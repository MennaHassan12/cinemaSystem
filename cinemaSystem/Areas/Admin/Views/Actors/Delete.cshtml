@model cinemaSystem.Models.Actor

@{
    ViewData["Title"] = "Delete Actor";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h4>Delete Actor</h4>
            </div>
            <div class="card-body">
                <p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>
                <form asp-area="Admin" asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    <a asp-area="Admin" asp-action="Index" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>