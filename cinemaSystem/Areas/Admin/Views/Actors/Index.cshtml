@model IEnumerable<cinemaSystem.Models.Actor>

@{
    ViewData["Title"] = "Actors";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div>

    <div class="d-flex justify-content-between align-items-center mb-3">

        <a asp-area="Admin"
           asp-controller="Actors"
           asp-action="Create"
           class="btn btn-primary">
            + Add New Actor
        </a>
    </div>

    <div class="card shadow-sm">

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Full Name</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var actor in Model)
                    {
                        <tr>

                            <td>
                                <img src="@(string.IsNullOrEmpty(actor.ImageUrl)
                                                                                 ? Url.Content("~/Images/default.png")
                                                                                 : actor.ImageUrl)"
                                     width="50"
                                     height="50"
                                     style="border-radius:50%; object-fit:cover;" />
                            </td>

                            <td>@actor.Name</td>

                            <td>
                                <a asp-area="Admin"
                                   asp-controller="Actors"
                                   asp-action="Edit"
                                   asp-route-id="@actor.Id"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-area="Admin"
                                   asp-controller="Actors"
                                   asp-action="Delete"
                                   asp-route-id="@actor.Id"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                            </td>

                        </tr>
                    }
                </tbody>

            </table>

        </div>

    </div>

</div>