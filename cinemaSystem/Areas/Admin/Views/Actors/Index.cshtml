@model IEnumerable<cinemaSystem.Models.Actor>

@{
    ViewData["Title"] = "Actors";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Actors List</h2>
        <a asp-area="Admin" asp-action="Create" class="btn btn-primary">+ Add New Actor</a>
    </div>

    <div class="table-container">
        <table class="table table-hover">
            <thead>
                <tr><th>Image</th><th>Full Name</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @foreach (var actor in Model)
                {
                    <tr>
                        <td><img src="@(string.IsNullOrEmpty(actor.ImageUrl) ? "" : actor.ImageUrl)" width="50" style="border-radius:50%; height:50px; object-fit:cover;"></td>
                        <td>@actor.Name</td>
                        <td>
                            <a asp-area="Admin" asp-action="Edit" asp-route-id="@actor.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-area="Admin" asp-action="Delete" asp-route-id="@actor.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>