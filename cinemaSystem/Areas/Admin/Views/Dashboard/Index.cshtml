@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-3">

    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 stat-card bg-primary text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Total Movies</h6>
                        <h3>@ViewBag.TotalMovies</h3>
                    </div>
                    <i class="fas fa-film fa-2x opacity-50"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 stat-card bg-success text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Total Actors</h6>
                        <h3>@ViewBag.TotalActors</h3>
                    </div>
                    <i class="fas fa-user fa-2x opacity-50"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 stat-card bg-warning text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Total Cinemas</h6>
                        <h3>@ViewBag.TotalCinemas</h3>
                    </div>
                    <i class="fas fa-building fa-2x opacity-50"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 stat-card bg-danger text-white">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6>Categories</h6>
                        <h3>@ViewBag.TotalCategories</h3>
                    </div>
                    <i class="fas fa-tags fa-2x opacity-50"></i>
                </div>
            </div>
        </div>

    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold">Recent Movies</h4>
    </div>

    <div class="row g-3">

        @foreach (var movie in ViewBag.RecentMovies)
        {
            <div class="col-md-4">

                <div class="card movie-card border-0 shadow-sm rounded-4 overflow-hidden">

                    <div class="position-relative">
                        <img src="@movie.MainImage"
                             class="w-100"
                             style="height:200px; object-fit:cover;" />

                        <span class="badge bg-dark position-absolute top-0 end-0 m-2">
                            @movie.Price.ToString("0.00")
                        </span>
                    </div>

                    <div class="card-body">
                        <h5 class="mb-1">@movie.Name</h5>
                        <small class="text-muted">
                            @movie.Category?.Name • @movie.Cinema?.Name
                        </small>
                    </div>

                </div>

            </div>
        }

    </div>

    <h4 class="mt-5 mb-3 fw-bold">Recent Actors</h4>

    <div class="row g-3">

        @foreach (var actor in ViewBag.RecentActors)
        {
            <div class="col-md-2 col-6">

                <div class="card border-0 shadow-sm text-center p-3 rounded-4 actor-card">

                    <img src="@actor.ImageUrl"
                         class="rounded-circle mx-auto"
                         style="width:75px;height:75px;object-fit:cover;" />

                    <h6 class="mt-2 mb-0">@actor.Name</h6>

                </div>

            </div>
        }

    </div>

</div>


    