@model cinemaSystem.ViewModel.RegisterVM

@{
    ViewData["Title"] = "Register";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">

        <div class="card shadow p-4">

            <h3 class="text-center mb-3">Register</h3>

            <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>

            <form method="post" action="/Identity/Account/Register">

                <div class="form-group mb-2">
                    <label>First Name</label>
                    <input name="FName" class="form-control" />
                </div>

                <div class="form-group mb-2">
                    <label>Last Name</label>
                    <input name="LName" class="form-control" />
                </div>

                <div class="form-group mb-2">
                    <label>Email</label>
                    <input name="Email" class="form-control" />
                </div>

                <div class="form-group mb-2">
                    <label>User Name</label>
                    <input name="UserName" class="form-control" />
                </div>

                <div class="form-group mb-2">
                    <label>Password</label>
                    <input name="Password" type="password" class="form-control" />
                </div>

                <div class="form-group mb-2">
                    <label>Confirm Password</label>
                    <input name="ConfirmPassword" type="password" class="form-control" />
                </div>

                <div class="form-group mb-3">
                    <label>Address</label>
                    <input name="Address" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Create Account
                </button>

            </form>

        </div>

    </div>
</div>